# FarmERP360 Environment Variables
# Copy this to .env and update values for production

# Database
DATABASE_URL=postgresql://farmerp360_user:farmerp360_secret_2024@postgres:5432/farmerp360
POSTGRES_DB=farmerp360
POSTGRES_USER=farmerp360_user
POSTGRES_PASSWORD=farmerp360_secret_2024

# Redis
REDIS_URL=redis://:farmerp360_redis_2024@redis:6379/0
REDIS_PASSWORD=farmerp360_redis_2024

# JWT Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=farmerp360_jwt_super_secret_key_change_in_production_2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=FarmERP360
